pipeline {
    agent {
        kubernetes {
            namespace 'yjlee'
            yaml """
                apiVersion: v1
                kind: Pod
                spec:
                  serviceAccountName: jenkins-agent
                  containers:
                    - name: maven
                      image: maven:3.9-eclipse-temurin-21
                      command: ['cat']
                      tty: true
                    - name: podman
                      image: quay.io/podman/stable:latest
                      command: ["sleep", "infinity"]
                      securityContext:
                        privileged: true
                      volumeMounts:
                      - name: podman-storage-vol
                        mountPath: /var/lib/containers
                      tty: true
                    - name: kubectl
                      image: alpine/k8s:1.29.15
                      command: ['cat']
                      tty: true
                  volumes:
                    - name: podman-storage-vol
                      emptyDir: {}
            """
        }
    }

    options {
            // 커밋 메시지에 [skip ci]가 포함되어 있으면 빌드를 수행하지 않음 (대소문자 구분 없음)
            // "App 소스 코드 저장소"와 "ArgoCD 배포 Manifest 저장소"를 분리하지 않고 하나의 Git 레포지토리에서 관리
            // manifest 이미지 태그를 변경하면 Git에 push 되고, Jenkins SCM은 이 커밋을 보고 pipeline 빌드를 시작함
            // 무한 배포 loop에 빠지기 때문에 이를 방지하기 위해 [skip ci] 라는 문구가 포함된 커밋은 무시하도록 설정.
            changelogExpression('(?i)^.*?\\[skip ci\\].*?$')
    }

    triggers {
        pollSCM('H/3 * * * *')
    }

    environment {
        IMAGE_NAME = "spring-server"
        IMAGE_TAG  = "${env.BUILD_NUMBER}"
        HARBOR_SERVER   = "harbor-product.strato.co.kr:8443"
        HARBOR_PROJECT  = "yjlee"
        HARBOR_REGISTRY = "harbor-product.strato.co.kr:8443/yjlee"
        HARBOR_CRED_ID = "harbor-robot-account-for-yjlee"
        GITHUB_CRED_ID = "yjlee-github-token"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/hey880/springhello.git'
            }
        }

        stage('Build Spring Boot with Nexus') {
            steps {
                // Nexus는 패키지만 줄 뿐이고 mvn 명령어를 쓰기 위해서는 maven 컨테이너가 필요하다.
                container('maven') {
                   // Jenkins Credentials에 등록된 Nexus 계정 ID 사용
                   withCredentials([usernamePassword(
                        credentialsId: 'nexus-login-credentials',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS')]
                   ) {
                       sh 'mvn clean package -s settings.xml -DskipTests'
                   }
                }
            }
        }

        stage('podman Build & Push to Harbor') {
            steps {
                container('podman') {
                    withCredentials([usernamePassword(
                        credentialsId: env.HARBOR_CRED_ID,
                        usernameVariable: 'HARBOR_USER', // Jenkins가 CredentialStore에서 값을 꺼내와 새로 만들어줄 환경변수의 이름
                        passwordVariable: 'HARBOR_PASS')]
                    ) {
                        sh """
                            podman build -t ${HARBOR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .
                            # --tls-verify=false 옵션 추가 (로그인, push 모두에 추가)
                            echo "\$HARBOR_PASS" | podman login ${HARBOR_SERVER} -u "\$HARBOR_USER" --password-stdin --tls-verify=false
                            podman push ${HARBOR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} --tls-verify=false
                        """
                    }
                }
            }
        }

        stage('Edit manifest files & Git Push') {
            steps {
                container('kubectl') {
                    withCredentials([usernamePassword(
                        credentialsId: env.GITHUB_CRED_ID,
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            # 1. 임시 공간으로 이동 후 새로 Clone
                            cd /tmp
                            rm -rf springhello
                            git clone https://\$GIT_USER:\$GIT_TOKEN@github.com/hey880/springhello.git
                            cd springhello

                            # 2. Git 유저 설정
                            git config user.name "hey880"
                            git config user.email "hey880@naver.com"

                            # 3. # 원본 템플릿(.tmpl)을 읽어서 -> 실제 배포용 파일(.yaml)을 생성
                            sed "s|__IMAGE_TAG__|${env.IMAGE_TAG}|g" k8s/deployment.tmpl > k8s/deployment.yaml

                            # 4. 변경 사항 반영 및 Push
                            git add k8s/deployment.yaml
                            git commit -m "Update deployment manifest image version: ${env.IMAGE_TAG} [skip ci]"
                            git push origin main
                        """
                    }
                }
            }
        }
    }

    post {
        failure {
            echo '파이프라인 실패!'
        }
    }
}